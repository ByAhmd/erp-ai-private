generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  Active
  Suspended
}

enum UserStatus {
  Active
  Invited
  Disabled
}

enum TenantUserStatus {
  Active
  Invited
  Disabled
}

enum AccountingPeriodStatus {
  Open
  Closed
  Adjusting
}

enum AccountType {
  Asset
  Liability
  Equity
  Revenue
  Expense
}

enum ChartOfAccountStatus {
  Active
  Inactive
}

enum JournalEntryStatus {
  Draft
  Posted
}

// ─── Phase 3 Enums (Business Documents) ──────────────────────────────────────

enum ContactType {
  Customer
  Supplier
  Employee
}

enum InvoiceType {
  SalesInvoice
  PurchaseInvoice
  CreditNote
  DebitNote
}

enum InvoiceStatus {
  Draft
  PendingApproval
  Approved
  Paid
  Cancelled
}

enum PaymentType {
  Incoming
  Outgoing
}

enum PaymentStatus {
  Draft
  PendingApproval
  Approved
  Reconciled
}

// ─── Phase 4 Enums (Compliance & Tax) ────────────────────────────────────────

enum ZatcaStatus {
  NotSubmitted
  Cleared
  Reported
  Failed
}

// ─── Phase 5 Enums (Extended Accounting) ─────────────────────────────────────

enum ReconciliationStatus {
  Draft
  Reconciled
}

enum AssetStatus {
  Draft
  Active
  Disposed
}

enum DepreciationMethod {
  StraightLine
  DecliningBalance
  UnitsOfProduction
}

enum ItemType {
  Product
  Service
}

enum InventoryTransactionType {
  Purchase
  Sale
  Adjustment
  Transfer
}

enum PayrollStatus {
  Draft
  PendingApproval
  Approved
  Paid
}

// ─── Phase 7 Enums (CRM, Procurement, HR) ────────────────────────────────────

enum Gender {
  Male
  Female
}

enum Religion {
  Muslim
  NonMuslim
}

enum LeaveType {
  Annual
  Sick
  Hajj
  Iddah
  Examination
  Unpaid
}

enum LeaveStatus {
  Pending
  Approved
  Rejected
}

enum PurchaseOrderStatus {
  Draft
  PendingApproval
  Sent
  PartiallyReceived
  Received
  Billed
  Cancelled
}

enum ApprovalStatus {
  Pending
  Approved
  Rejected
  Cancelled
}

enum OpportunityStage {
  Prospecting
  Qualification
  Proposal
  Negotiation
  Won
  Lost
}

enum QuoteStatus {
  Draft
  Sent
  Accepted
  Rejected
  Expired
}

// ─── Core Identity ───────────────────────────────────────────────────────────

model ApprovalRequest {
  id              String         @id @default(uuid())
  tenantId        String
  entityType      String         // e.g. "PurchaseOrder", "PayrollRun", "LeaveRequest"
  entityId        String         // The ID of the record
  requestedById   String         // User who initiated the request
  approverId      String?        // User assigned to approve
  status          ApprovalStatus @default(Pending)
  comments        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  requestedBy     User           @relation("RequestedApprovals", fields: [requestedById], references: [id])
  approver        User?          @relation("AssignedApprovals", fields: [approverId], references: [id])

  @@index([tenantId])
  @@index([entityType, entityId])
}

model Tenant {
  id                String                 @id @default(uuid())
  name              String
  commercialRegNo   String?
  vatRegistrationNo String?
  country           String                 @default("SA")
  currency          String                 @default("SAR")
  status            TenantStatus           @default(Active)
  settings          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  tenantUsers       TenantUser[]
  roles             Role[]
  permissions       Permission[]
  auditLogs         AuditLog[]
  branches          Branch[]
  costCenters       CostCenter[]
  accountingPeriods AccountingPeriod[]
  fiscalYears       FiscalYear[]
  chartOfAccounts   ChartOfAccount[]
  journalEntries    JournalEntry[]
  currencies        Currency[]
  exchangeRates     ExchangeRate[]
  contacts          Contact[]
  sequences         DocumentSequence[]
  invoices          Invoice[]
  payments          Payment[]
  taxCodes          TaxCode[]
  whtRates          WhtRate[]
  zakatSettings     ZakatSetting[]
  employeeProfiles  EmployeeProfile[]
  bankStatements    BankStatement[]
  reconciliations   Reconciliation[]
  fixedAssets       FixedAsset[]
  items             Item[]
  warehouses        Warehouse[]
  inventoryTxns     InventoryTransaction[]
  payrollRuns       PayrollRun[]
  tenantChildren    TenantHierarchy[]      @relation("ParentTenant")
  tenantParents     TenantHierarchy[]      @relation("ChildTenant")
  periodExRates     PeriodExchangeRate[]
  leaveRequests     LeaveRequest[]
  purchaseOrders    PurchaseOrder[]
  opportunities     Opportunity[]
  quotes            Quote[]
  approvalRequests  ApprovalRequest[]

  @@index([status])
}

model User {
  id                  String       @id @default(uuid())
  email               String       @unique
  fullName            String
  passwordHash        String?
  passwordChangedAt   DateTime?
  failedLoginAttempts Int          @default(0)
  lockedUntil         DateTime?
  mfaEnabled          Boolean      @default(false)
  mfaSecret           String?
  status              UserStatus   @default(Invited)
  inviteTokenHash     String?
  inviteTokenExpiresAt DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  tenantUsers         TenantUser[]
  auditLogs           AuditLog[]
  requestedApprovals  ApprovalRequest[] @relation("RequestedApprovals")
  assignedApprovals   ApprovalRequest[] @relation("AssignedApprovals")

  @@index([email])
  @@index([status])
}

model TenantUser {
  id        String           @id @default(uuid())
  tenantId  String
  userId    String
  roleId    String?
  status    TenantUserStatus @default(Invited)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  role      Role?            @relation(fields: [roleId], references: [id])

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

// ─── Authorization ───────────────────────────────────────────────────────────

model Role {
  id              String           @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  isSystemRole    Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  tenantUsers     TenantUser[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id              String           @id @default(uuid())
  tenantId        String
  key             String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  actorUser   User?    @relation(fields: [actorUserId], references: [id])

  @@index([tenantId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
}

// ─── Organization ────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  code      String
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
}

model CostCenter {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  code      String
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ─── Accounting ──────────────────────────────────────────────────────────────

model FiscalYear {
  id                String                 @id @default(uuid())
  tenantId          String
  name              String
  startDate         DateTime
  endDate           DateTime
  status            AccountingPeriodStatus @default(Open)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  tenant            Tenant                 @relation(fields: [tenantId], references: [id])
  accountingPeriods AccountingPeriod[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, status])
}

model AccountingPeriod {
  id           String                 @id @default(uuid())
  tenantId     String
  fiscalYearId String
  name         String
  startDate    DateTime
  endDate      DateTime
  status       AccountingPeriodStatus @default(Open)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  fiscalYear   FiscalYear             @relation(fields: [fiscalYearId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([fiscalYearId])
  @@index([tenantId, status])
}

model ChartOfAccount {
  id             String               @id @default(uuid())
  tenantId       String
  parentId       String?
  code           String
  name           String
  type           AccountType
  status         ChartOfAccountStatus @default(Active)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  currencyId     String?
  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  parent         ChartOfAccount?      @relation("ChartOfAccountHierarchy", fields: [parentId], references: [id])
  children       ChartOfAccount[]     @relation("ChartOfAccountHierarchy")
  currency       Currency?            @relation(fields: [currencyId], references: [id])
  journalLines   JournalEntryLine[]
  bankStatements BankStatement[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@index([currencyId])
}

model JournalEntry {
  id          String             @id @default(uuid())
  tenantId    String
  entryNumber String
  entryDate   DateTime
  description String?
  status      JournalEntryStatus @default(Draft)
  reversalId  String?            @unique
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  reversal    JournalEntry?      @relation("JournalEntryReversal", fields: [reversalId], references: [id])
  reversedBy  JournalEntry?      @relation("JournalEntryReversal")
  lines       JournalEntryLine[]

  @@unique([tenantId, entryNumber])
  @@index([tenantId])
  @@index([tenantId, status])
}

model JournalEntryLine {
  id               String          @id @default(uuid())
  tenantId         String
  journalEntryId   String
  accountId        String
  description      String?
  debit            Decimal         @default(0) @db.Decimal(18, 2)
  credit           Decimal         @default(0) @db.Decimal(18, 2)
  currencyId       String?
  foreignDebit     Decimal?        @db.Decimal(18, 2)
  foreignCredit    Decimal?        @db.Decimal(18, 2)
  exchangeRate     Decimal?        @db.Decimal(18, 6)
  contactId        String?
  taxCodeId        String?
  reconciliationId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  journalEntry     JournalEntry    @relation(fields: [journalEntryId], references: [id])
  account          ChartOfAccount  @relation(fields: [accountId], references: [id])
  currency         Currency?       @relation(fields: [currencyId], references: [id])
  contact          Contact?        @relation(fields: [contactId], references: [id])
  reconciliation   Reconciliation? @relation(fields: [reconciliationId], references: [id])

  @@index([tenantId])
  @@index([journalEntryId])
  @@index([accountId])
  @@index([currencyId])
  @@index([contactId])
  @@index([taxCodeId])
  @@index([reconciliationId])
}

model Currency {
  id            String             @id @default(uuid())
  tenantId      String
  code          String
  name          String
  symbol        String?
  isBase        Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  exchangeRates ExchangeRate[]
  accounts      ChartOfAccount[]
  journalLines  JournalEntryLine[]
  invoices      Invoice[]
  payments      Payment[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ExchangeRate {
  id         String   @id @default(uuid())
  tenantId   String
  currencyId String
  date       DateTime
  rate       Decimal  @db.Decimal(18, 6)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  currency   Currency @relation(fields: [currencyId], references: [id])

  @@unique([tenantId, currencyId, date])
  @@index([tenantId])
}

// ─── Business Documents (Phase 3) ────────────────────────────────────────────

model Contact {
  id                  String             @id @default(uuid())
  tenantId            String
  type                ContactType        @default(Customer)
  name                String
  email               String?
  phone               String?
  commercialRegNo     String?
  vatRegistrationNo   String?
  billingAddress      String?
  shippingAddress     String?
  receivableAccountId String?
  payableAccountId    String?
  isBusinessCustomer  Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  journalLines        JournalEntryLine[]
  invoices            Invoice[]
  payments            Payment[]
  employeeProfile     EmployeeProfile?
  purchaseOrders      PurchaseOrder[]
  opportunities       Opportunity[]
  quotes              Quote[]

  @@index([tenantId])
  @@index([tenantId, type])
}

model DocumentSequence {
  id         String   @id @default(uuid())
  tenantId   String
  entityType String
  prefix     String
  nextNumber Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, entityType])
}

model Invoice {
  id             String              @id @default(uuid())
  tenantId       String
  invoiceNumber  String
  contactId      String
  type           InvoiceType
  status         InvoiceStatus       @default(Draft)
  issueDate      DateTime
  dueDate        DateTime?
  currencyId     String?
  exchangeRate   Decimal?            @db.Decimal(18, 6)
  subTotal       Decimal             @default(0) @db.Decimal(18, 2)
  taxTotal       Decimal             @default(0) @db.Decimal(18, 2)
  total          Decimal             @default(0) @db.Decimal(18, 2)
  amountPaid     Decimal             @default(0) @db.Decimal(18, 2)
  notes          String?
  journalEntryId String?             @unique
  zatcaPih       String?
  zatcaUuid      String?
  zatcaQrCode    String?
  zatcaXml       String?             @db.Text
  zatcaHash      String?
  zatcaStatus    ZatcaStatus         @default(NotSubmitted)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  contact        Contact             @relation(fields: [contactId], references: [id])
  currency       Currency?           @relation(fields: [currencyId], references: [id])
  lines          InvoiceLine[]
  allocations    PaymentAllocation[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([contactId])
  @@index([tenantId, status])
}

model InvoiceLine {
  id          String     @id @default(uuid())
  tenantId    String
  invoiceId   String
  description String
  quantity    Decimal    @default(1) @db.Decimal(18, 2)
  unitPrice   Decimal    @db.Decimal(18, 2)
  taxRate     Decimal    @default(0) @db.Decimal(5, 2)
  taxAmount   Decimal    @default(0) @db.Decimal(18, 2)
  total       Decimal    @db.Decimal(18, 2)
  accountId   String
  itemId      String?
  warehouseId String?
  taxCodeId   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  invoice     Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item        Item?      @relation(fields: [itemId], references: [id])
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@index([taxCodeId])
}

model Payment {
  id             String              @id @default(uuid())
  tenantId       String
  paymentNumber  String
  contactId      String
  type           PaymentType
  status         PaymentStatus       @default(Draft)
  paymentDate    DateTime
  amount         Decimal             @db.Decimal(18, 2)
  currencyId     String?
  exchangeRate   Decimal?            @db.Decimal(18, 6)
  reference      String?
  notes          String?
  accountId      String // The bank/cash account receiving or sending the money
  whtAmount      Decimal             @default(0) @db.Decimal(18, 2)
  whtAccountId   String?
  journalEntryId String?             @unique
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  contact        Contact             @relation(fields: [contactId], references: [id])
  currency       Currency?           @relation(fields: [currencyId], references: [id])
  allocations    PaymentAllocation[]

  @@unique([tenantId, paymentNumber])
  @@index([tenantId])
  @@index([contactId])
  @@index([tenantId, status])
}

model PaymentAllocation {
  id        String   @id @default(uuid())
  tenantId  String
  paymentId String
  invoiceId String
  amount    Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([paymentId])
  @@index([invoiceId])
}

// ─── Compliance & Tax (Phase 4) ──────────────────────────────────────────────

model TaxCode {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  rate      Decimal  @db.Decimal(5, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ZakatSetting {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  isHijriYear         Boolean  @default(true)
  zakatBaseMultiplier Decimal  @default(2.5) @db.Decimal(5, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
}

model WhtRate {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  rate      Decimal  @db.Decimal(5, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
}

model EmployeeProfile {
  id                 String  @id @default(uuid())
  tenantId           String
  contactId          String  @unique
  gosiNumber         String?
  basicSalary        Decimal @default(0) @db.Decimal(18, 2)
  housingAllowance   Decimal @default(0) @db.Decimal(18, 2)
  transportAllowance Decimal @default(0) @db.Decimal(18, 2)

  // KSA HR fields
  hireDate       DateTime?
  gender         Gender?
  religion       Religion?
  contractSalary Decimal   @default(0) @db.Decimal(18, 2)
  qiwaContractId String?
  hajjLeaveUsed  Boolean   @default(false)
  
  // Bank details for WPS
  bankName       String?
  iban           String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  contact       Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]

  @@index([tenantId])
}

// ─── Extended Accounting (Phase 5) ───────────────────────────────────────────

// Bank Reconciliation
model BankStatement {
  id              String                     @id @default(uuid())
  tenantId        String
  accountId       String
  statementDate   DateTime
  openingBalance  Decimal                    @db.Decimal(18, 2)
  closingBalance  Decimal                    @db.Decimal(18, 2)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  tenant          Tenant                     @relation(fields: [tenantId], references: [id])
  account         ChartOfAccount             @relation(fields: [accountId], references: [id])
  transactions    BankStatementTransaction[]
  reconciliations Reconciliation[]

  @@index([tenantId])
  @@index([accountId])
}

model BankStatementTransaction {
  id              String        @id @default(uuid())
  bankStatementId String
  date            DateTime
  description     String
  amount          Decimal       @db.Decimal(18, 2)
  reference       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  bankStatement   BankStatement @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)

  @@index([bankStatementId])
}

model Reconciliation {
  id              String               @id @default(uuid())
  tenantId        String
  bankStatementId String
  accountId       String
  status          ReconciliationStatus @default(Draft)
  reconciledAt    DateTime?
  reconciledById  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  bankStatement   BankStatement        @relation(fields: [bankStatementId], references: [id])
  journalLines    JournalEntryLine[]

  @@index([tenantId])
  @@index([bankStatementId])
}

// Fixed Assets
model FixedAsset {
  id                    String                 @id @default(uuid())
  tenantId              String
  code                  String
  name                  String
  description           String?
  assetAccountId        String
  depreciationAccountId String
  expenseAccountId      String
  purchaseDate          DateTime
  purchasePrice         Decimal                @db.Decimal(18, 2)
  salvageValue          Decimal                @db.Decimal(18, 2)
  usefulLifeMonths      Int
  depreciationMethod    DepreciationMethod     @default(StraightLine)
  status                AssetStatus            @default(Draft)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  schedules             DepreciationSchedule[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model DepreciationSchedule {
  id             String     @id @default(uuid())
  fixedAssetId   String
  date           DateTime
  amount         Decimal    @db.Decimal(18, 2)
  accumulated    Decimal    @db.Decimal(18, 2)
  journalEntryId String?    @unique
  posted         Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  fixedAsset     FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@index([fixedAssetId])
}

// Inventory
model Item {
  id                   String                 @id @default(uuid())
  tenantId             String
  type                 ItemType               @default(Product)
  code                 String
  name                 String
  description          String?
  inventoryAccountId   String?
  cogsAccountId        String?
  revenueAccountId     String?
  weightedAverageCost  Decimal                @default(0) @db.Decimal(18, 2)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  tenant               Tenant                 @relation(fields: [tenantId], references: [id])
  invoiceLines         InvoiceLine[]
  inventoryBalances    InventoryBalance[]
  inventoryLots        InventoryLot[]
  InventoryTransaction InventoryTransaction[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Warehouse {
  id                   String                 @id @default(uuid())
  tenantId             String
  code                 String
  name                 String
  location             String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  tenant               Tenant                 @relation(fields: [tenantId], references: [id])
  inventoryBalances    InventoryBalance[]
  inventoryLots        InventoryLot[]
  invoiceLines         InvoiceLine[]
  InventoryTransaction InventoryTransaction[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model InventoryBalance {
  id          String    @id @default(uuid())
  itemId      String
  warehouseId String
  quantity    Decimal   @default(0) @db.Decimal(18, 4)
  updatedAt   DateTime  @updatedAt
  item        Item      @relation(fields: [itemId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([itemId, warehouseId])
}

// Support for FIFO in the future
model InventoryLot {
  id          String    @id @default(uuid())
  itemId      String
  warehouseId String
  lotNumber   String
  quantity    Decimal   @db.Decimal(18, 4)
  unitCost    Decimal   @db.Decimal(18, 6)
  receivedAt  DateTime  @default(now())
  item        Item      @relation(fields: [itemId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([itemId, warehouseId])
}

model InventoryTransaction {
  id             String                   @id @default(uuid())
  tenantId       String
  type           InventoryTransactionType
  itemId         String
  warehouseId    String
  quantity       Decimal                  @db.Decimal(18, 4)
  unitCost       Decimal                  @db.Decimal(18, 6)
  date           DateTime
  reference      String?
  journalEntryId String?                  @unique
  createdAt      DateTime                 @default(now())
  tenant         Tenant                   @relation(fields: [tenantId], references: [id])
  item           Item                     @relation(fields: [itemId], references: [id])
  warehouse      Warehouse                @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([itemId])
}

// Consolidation
model TenantHierarchy {
  id             String   @id @default(uuid())
  parentTenantId String
  childTenantId  String
  ownershipPct   Decimal  @default(100) @db.Decimal(5, 2)
  createdAt      DateTime @default(now())
  parentTenant   Tenant   @relation("ParentTenant", fields: [parentTenantId], references: [id])
  childTenant    Tenant   @relation("ChildTenant", fields: [childTenantId], references: [id])

  @@unique([parentTenantId, childTenantId])
}

model EliminationEntry {
  id             String   @id @default(uuid())
  tenantId       String // The parent tenant
  periodId       String
  journalEntryId String   @unique
  createdAt      DateTime @default(now())

  @@index([tenantId, periodId])
}

model PeriodExchangeRate {
  id                 String   @id @default(uuid())
  tenantId           String
  accountingPeriodId String
  currencyId         String
  rate               Decimal  @db.Decimal(18, 6)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, accountingPeriodId, currencyId])
}

// Payroll
model PayrollRun {
  id                    String        @id @default(uuid())
  tenantId              String
  periodName            String // e.g., "July 2026"
  status                PayrollStatus @default(Draft)
  totalGross            Decimal       @default(0) @db.Decimal(18, 2)
  totalNet              Decimal       @default(0) @db.Decimal(18, 2)
  totalDeductions       Decimal       @default(0) @db.Decimal(18, 2)
  totalGosi             Decimal       @default(0) @db.Decimal(18, 2)
  totalOtherDeductions  Decimal       @default(0) @db.Decimal(18, 2)
  journalEntryId        String?       @unique
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  tenant                Tenant        @relation(fields: [tenantId], references: [id])
  payslips              Payslip[]

  @@unique([tenantId, periodName])
  @@index([tenantId])
}

model Payslip {
  id                String     @id @default(uuid())
  payrollRunId      String
  employeeProfileId String
  grossSalary       Decimal    @db.Decimal(18, 2)
  gosiDeduction     Decimal    @db.Decimal(18, 2)
  otherDeductions   Decimal    @default(0) @db.Decimal(18, 2)
  netSalary         Decimal    @db.Decimal(18, 2)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  payrollRun        PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeProfileId])
  @@index([payrollRunId])
}

// ─── Phase 7 Models (HR, Procurement, CRM) ───────────────────────────────────

model LeaveRequest {
  id                String          @id @default(uuid())
  tenantId          String
  employeeProfileId String
  type              LeaveType
  startDate         DateTime
  endDate           DateTime
  status            LeaveStatus     @default(Pending)
  reason            String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  employeeProfile   EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeProfileId])
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  tenantId     String
  poNumber     String
  contactId    String // Supplier
  status       PurchaseOrderStatus @default(Draft)
  issueDate    DateTime
  deliveryDate DateTime?
  totalAmount  Decimal             @default(0) @db.Decimal(18, 2)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  contact      Contact             @relation(fields: [contactId], references: [id])
  lines        PurchaseOrderLine[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([contactId])
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  description     String
  quantity        Decimal       @default(1) @db.Decimal(18, 2)
  unitPrice       Decimal       @db.Decimal(18, 2)
  total           Decimal       @db.Decimal(18, 2)
  itemId          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model Opportunity {
  id            String           @id @default(uuid())
  tenantId      String
  contactId     String // Client/Lead
  title         String
  stage         OpportunityStage @default(Prospecting)
  value         Decimal          @default(0) @db.Decimal(18, 2)
  expectedClose DateTime?
  probability   Int              @default(0) // 0-100
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  contact       Contact          @relation(fields: [contactId], references: [id])
  quotes        Quote[]

  @@index([tenantId])
  @@index([contactId])
}

model Quote {
  id            String       @id @default(uuid())
  tenantId      String
  opportunityId String?
  contactId     String
  quoteNumber   String
  status        QuoteStatus  @default(Draft)
  issueDate     DateTime
  expiryDate    DateTime?
  totalAmount   Decimal      @default(0) @db.Decimal(18, 2)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  contact       Contact      @relation(fields: [contactId], references: [id])

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
  @@index([contactId])
}
