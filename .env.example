# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://erp_ai:erp_ai_password@localhost:5432/erp_ai?schema=public"

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"
API_PREFIX="api/v1"
CORS_ORIGIN="http://localhost:3000"

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING_IN_PRODUCTION"
JWT_EXPIRES_IN="900"
JWT_REFRESH_SECRET="CHANGE_ME_TO_A_DIFFERENT_RANDOM_64_CHAR_STRING"
JWT_REFRESH_EXPIRES_IN="604800"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="erp_ai_redis_password"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"
RATE_LIMIT_AUTH_TTL="60"
RATE_LIMIT_AUTH_MAX="5"

# ─── Password Policy (Platform Minimum Baseline) ─────────────────────────────
PASSWORD_MIN_LENGTH="12"
PASSWORD_REQUIRE_UPPERCASE="true"
PASSWORD_REQUIRE_LOWERCASE="true"
PASSWORD_REQUIRE_DIGIT="true"
PASSWORD_REQUIRE_SPECIAL="true"
PASSWORD_MAX_FAILED_ATTEMPTS="5"
PASSWORD_LOCKOUT_DURATION_MINUTES="30"

# ─── Argon2 ───────────────────────────────────────────────────────────────────
ARGON2_MEMORY_COST="65536"
ARGON2_TIME_COST="3"
ARGON2_PARALLELISM="4"

# ─── Admin Seed ───────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@erp-ai.local"
SEED_ADMIN_PASSWORD="CHANGE_ME_IN_PRODUCTION_Str0ng!Pass"
SEED_ADMIN_FULL_NAME="Platform Administrator"
